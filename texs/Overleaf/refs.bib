@article{deeppeptide2023,
    author = {Teufel, Felix and Refsgaard, Jan Christian and Madsen, Christian Toft and Stahlhut, Carsten and Grønborg, Mads and Winther, Ole and Madsen, Dennis},
    title = {DeepPeptide predicts cleaved peptides in proteins using conditional random fields},
    journal = {Bioinformatics},
    volume = {39},
    number = {10},
    pages = {btad616},
    year = {2023},
    month = {10},
    abstract = {Peptides are ubiquitous throughout life and involved in a wide range of biological processes, ranging from neural signaling in higher organisms to antimicrobial peptides in bacteria. Many peptides are generated post-translationally by cleavage of precursor proteins and can thus not be detected directly from genomics data, as the specificities of the responsible proteases are often not completely understood.We present DeepPeptide, a deep learning model that predicts cleaved peptides directly from the amino acid sequence. DeepPeptide shows both improved precision and recall for peptide detection compared to previous methodology. We show that the model is capable of identifying peptides in underannotated proteomes.DeepPeptide is available online at ku.biolib.com/DeepPeptide.},
    issn = {1367-4811},
    doi = {10.1093/bioinformatics/btad616},
    url = {https://doi.org/10.1093/bioinformatics/btad616},
    eprint = {https://academic.oup.com/bioinformatics/article-pdf/39/10/btad616/52241432/btad616.pdf},
}

